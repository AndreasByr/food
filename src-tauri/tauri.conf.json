{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Foodora",
  "version": "0.1.0",
  "identifier": "org.foodora.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build:tauri",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../.output/public"
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Foodora",
        "width": 400,
        "height": 800,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {}
}
