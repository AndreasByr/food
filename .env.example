# ── Foodora backend env (no real values committed) ──
# Postgres connection string used by Drizzle + postgres.js.
# Local dev: postgres://postgres:dev@localhost:5432/foodora
DATABASE_URL=
# Secret used to sign/verify JWT (access + refresh). Min 32 random bytes.
JWT_SECRET=
# Access token TTL in seconds (default 15 min).
JWT_ACCESS_TTL=900
# Refresh token TTL in seconds (default 7 days).
JWT_REFRESH_TTL=604800